  "contact": {
    "homepage": "https://modrinth.com/mod/friendcreeper",
    "sources": "https://github.com/smalldayDC/friendlycreeper",
    "issues": "https://github.com/smalldayDC/friendlycreeper/issues"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.smalldaydc.friendlycreeper.FriendlyCreeperMod"],
    "client": ["com.smalldaydc.friendlycreeper.client.FriendlyCreeperClient"]
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.curseforge": "https://www.curseforge.com/minecraft/mc-mods/friend-creeper"
      }
    }
  },
  "mixins": [
    "friendlycreeper.mixins.json",
    "friendlycreeper.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "fabric-api": ">=0.116.9",
    "minecraft": "1.21.1"
  }
